# 依存
node_modules/

# ビルド出力
dist/
build/
.astro/
.next/
.output/
coverage/

# 環境変数（秘密値は絶対にコミットしない）
.env
.env.local
.env.*.local

# ログ
*.log
npm-debug.log*

# OS / IDE
.DS_Store
.vscode/
.idea/

# Claude Code（rules / commands のみ追跡し、その他のローカル設定は除外）
.claude/*
!.claude/rules/
!.claude/commands/

# 発信の生成下書き（WIP は追跡しない）
marketing/drafts/*
!marketing/drafts/.gitkeep

# 一時物
.tmp/
.bin/
